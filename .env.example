# GeoDeploy environment — copy to .env and fill in secrets
# Lines marked "set by wizard" are written programmatically; leave blank here.

# Core
GEODEPLOY_SECRET_KEY=change-this-to-a-long-random-string
GEODEPLOY_HOST=0.0.0.0
GEODEPLOY_PORT=8000
GEODEPLOY_ENV=production
GEODEPLOY_DATA_DIR=/data

# Active Docker Compose profiles — which optional LOCAL containers this install runs.
# Set by the wizard: "local-db" if you let GeoDeploy provision PostGIS, "local-storage" if it
# provisions MinIO (comma-separated; empty when you connect your own external DB/storage).
# docker compose reads this automatically so install/update keep those containers managed.
COMPOSE_PROFILES=

# PostGIS — managed by GeoDeploy (set by wizard)
POSTGIS_HOST=postgres
POSTGIS_PORT=5432
POSTGIS_DB=geodeploy
POSTGIS_USER=geodeploy
POSTGIS_PASSWORD=
# Blank for the local provisioned DB (no TLS). The wizard sets this to "prefer" for an
# existing/external DB; use "require"/"verify-full" for a managed DB that mandates SSL.
POSTGIS_SSLMODE=

# Storage (set by wizard)
STORAGE_TYPE=minio
STORAGE_ENDPOINT=http://minio:9000
STORAGE_BUCKET=geodeploy
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Tile servers
MARTIN_URL=http://martin:3000
MARTIN_CONFIG_PATH=/data/martin/martin-config.yaml
TITILER_URL=http://titiler:80
# Host:port (no scheme) for GDAL/TiTiler S3 access — set by wizard
TITILER_S3_ENDPOINT=
# YES for a real (HTTPS) S3, NO for the local MinIO — set by wizard from the endpoint scheme
TITILER_AWS_HTTPS=NO

# Optional: external S3 override
# STORAGE_TYPE=s3
# STORAGE_ENDPOINT=https://s3.amazonaws.com
# STORAGE_REGION=eu-west-1

# Optional: Sentry
# SENTRY_DSN=
